# Contract deployment configuration
# Blueprint loads this file automatically when you run commands from apps/contracts.

# Optional generic fallbacks used when the network-specific key is not set.
# COLLECTION_CONTENT_URL=https://example.com/collection.json
# COMMON_CONTENT_URL=https://example.com/nft/
# ROYALTY_NUMERATOR=0
# ROYALTY_DENOMINATOR=1
# ROYALTY_DESTINATION=EQ...
# DEPLOY_VALUE=0.05
# COLLECTION_ADDRESS=EQ...
# NEW_ROYALTY_NUMERATOR=25
# NEW_ROYALTY_DENOMINATOR=1000
# NEW_ROYALTY_DESTINATION=EQ...
# UPDATE_ROYALTY_VALUE=0.05

# Testnet deployment
TESTNET_COLLECTION_CONTENT_URL=https://testnet.example.com/collection.json
TESTNET_COMMON_CONTENT_URL=https://testnet.example.com/nft/
TESTNET_ROYALTY_NUMERATOR=0
TESTNET_ROYALTY_DENOMINATOR=1
# Optional; defaults to the deployer wallet address
TESTNET_ROYALTY_DESTINATION=
TESTNET_DEPLOY_VALUE=0.05
TESTNET_COLLECTION_ADDRESS=EQ...
TESTNET_NEW_ROYALTY_NUMERATOR=25
TESTNET_NEW_ROYALTY_DENOMINATOR=1000
# Optional; defaults to the current on-chain royalty destination
TESTNET_NEW_ROYALTY_DESTINATION=
TESTNET_UPDATE_ROYALTY_VALUE=0.05

# Mainnet deployment
MAINNET_COLLECTION_CONTENT_URL=https://example.com/collection.json
MAINNET_COMMON_CONTENT_URL=https://example.com/nft/
MAINNET_ROYALTY_NUMERATOR=0
MAINNET_ROYALTY_DENOMINATOR=1
# Optional; defaults to the deployer wallet address
MAINNET_ROYALTY_DESTINATION=
MAINNET_DEPLOY_VALUE=0.05
MAINNET_COLLECTION_ADDRESS=EQ...
MAINNET_NEW_ROYALTY_NUMERATOR=25
MAINNET_NEW_ROYALTY_DENOMINATOR=1000
# Optional; defaults to the current on-chain royalty destination
MAINNET_NEW_ROYALTY_DESTINATION=
MAINNET_UPDATE_ROYALTY_VALUE=0.05

# Optional when using --mnemonic instead of --tonconnect
# WALLET_MNEMONIC=word1 word2 word3 ...
# WALLET_VERSION=v4R2
